{
    "name": "felixmuhoro/laravel-mpesa-invoices",
    "description": "Auto-generates professional PDF invoices for M-Pesa payments and stores/emails them",
    "type": "library",
    "keywords": ["laravel", "mpesa", "invoice", "pdf", "kenya"],
    "homepage": "https://github.com/felixmuhoro/laravel-mpesa-invoices",
    "license": "MIT",
    "authors": [
        {
            "name": "Felix Muhoro",
            "email": "hi@felixmuhoro.dev"
        }
    ],
    "require": {
        "php": "^8.1",
        "felixmuhoro/laravel-mpesa": "^1.2",
        "barryvdh/laravel-dompdf": "^2.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/mail": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "FelixMuhoro\\MpesaInvoices\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FelixMuhoro\\MpesaInvoices\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FelixMuhoro\\MpesaInvoices\\MpesaInvoicesServiceProvider"
            ],
            "aliases": {
                "MpesaInvoice": "FelixMuhoro\\MpesaInvoices\\Facades\\MpesaInvoice"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
